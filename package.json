{
  "name": "brama",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "brama-web",
    "brama-be"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"npm run dev -w brama-web\" \"npm run dev -w brama-be\"",
    "dev:web": "npm run dev -w brama-web",
    "dev:api": "npm run dev -w brama-be",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "dependencies": {
    "react-glass-ui": "^1.2.2"
  }
}
