NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
CHAT_DATABASE_PATH=./data/chats.db
DEPARTMENTS_DATABASE_PATH=./data/brama.db
OLLAMA_CHAT_MODEL=SpeakLeash/bielik-4.5b-v3.0-instruct:Q8_0
OLLAMA_TRANSLATION_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=bge-m3
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=bip_services
RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.45
RAG_ENABLED=true
# Path to the parsed BIP data dir used by `npm run ingest` (relative to brama-be)
BIP_DATA_DIR=../docs/bip_db
# Neo4j service dependency graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
GRAPH_ENABLED=true
# Google Maps Platform — one key with Geocoding API + Routes API + Maps JavaScript API
# enabled (Geocoding used by `npm run geocode`, Routes used at runtime, Maps JS by the
# React client). SET A BILLING CAP in the GCP console — this key is also shipped to the
# browser and Routes API is billable.
GOOGLE_MAPS_API_KEY=AIzaSyCBhWeIZaomOXthyJaVCUaX_dQ-w7akQIA
MAPS_ENABLED=true
